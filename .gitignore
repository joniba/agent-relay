# Local-only working/planning docs (plans, designs, notes, probes) — never committed.
working-docs/

# In-repo git worktrees (feature work) — never tracked.
worktrees/

# Playwright MCP scratch (browser snapshots/logs)
.playwright-mcp/

# Node
node_modules/

# Local environment / secrets — never commit connection settings or tokens
.env
.env.*
!.env.example

# Local mesh state + logs (the default sqlite-poll transport's store)
*.db
*.db-wal
*.db-shm
*.wal
*.sqlite
logs/
.andromeda/
