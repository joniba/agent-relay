# agent-relay — cross-machine configuration template.
#
# Copy this to `.env` (gitignored) and fill in your values:
#     cp .env.example extension/.env      # next to extension.mjs (recommended)
#   or place it at the repo root, or point $AGENT_RELAY_ENV_FILE at it.
#
# The extension auto-loads it at startup. Values already exported in your shell
# take precedence (the file only fills gaps), so you can still override ad-hoc.
#
# GOTCHA: quote any value containing '#' (e.g. an Entra guest UPN) — otherwise the
# parser treats '#' as the start of a comment and truncates the value.

AGENT_RELAY_TRANSPORT=postgres
AGENT_RELAY_PG_HOST=pg-agent-relay-<unique>.postgres.database.azure.com
AGENT_RELAY_PG_USER="<your-entra-admin-upn>"
AGENT_RELAY_PG_DB=agentrelay

# Microsoft Entra tenant id of the database. Set this when your account spans
# multiple tenants or the DB tenant enforces MFA — the installer then does
# `az login --tenant <id>` and the token targets that tenant explicitly (avoids
# AADSTS50076 / "no subscriptions found"). Omit when your `az login` already
# targets the database tenant without MFA/tenant-enumeration issues.
# Find it with:  az account show --query tenantId -o tsv  (signed into that tenant)
# AGENT_RELAY_AZURE_TENANT=00000000-0000-0000-0000-000000000000

# Mint the Entra token as the DB admin via an isolated `az` profile. Omit if your
# default `az login` is already that identity.
# AZURE_CONFIG_DIR=C:\path\to\.azure-relay

# Optional display label shown beside this session in the roster (defaults to the
# machine hostname).
# AGENT_RELAY_HOST=laptop

# Directory for local state (the SQLite store) + rolling diagnostic logs. Defaults
# to a per-user OS data dir (e.g. %LOCALAPPDATA%\agent-relay on Windows,
# ~/Library/Application Support/agent-relay on macOS, $XDG_DATA_HOME/agent-relay (or
# ~/.local/share/agent-relay) on Linux). Override to relocate them.
# AGENT_RELAY_DATA_DIR=C:\path\to\agent-relay-data

# Verbose diagnostics. When set (1|true|yes|on) the Postgres transport logs every
# periodic cleanup ("sweep") to the session timeline; silent otherwise. Sweep
# errors are always shown regardless of this flag.
# AGENT_RELAY_DEBUG=1

# Load EXTERNAL plugin modules (interceptors / transport / credentials / identity) at
# startup, folded into a registry — so a capability can live in a separate (private) repo
# or a local folder, not in this one. Both optional; with no paths set AND no plugins in
# the plugin dir, nothing loads. Each module default-exports a factory (ctx)=>Registration —
# see the README "External plugins" section for the contract.
#   - AGENT_RELAY_PLUGINS:    comma-separated module paths (absolute or cwd-relative),
#     loaded in listed order (a secondary dev convenience).
#   - AGENT_RELAY_PLUGIN_DIR: a folder whose top-level *.mjs + package subfolders are loaded
#     alphabetically (default: the extension's OWN plugins/ folder, next to extension.mjs).
# AGENT_RELAY_PLUGINS=C:\path\to\my-plugin\index.mjs
# AGENT_RELAY_PLUGIN_DIR=C:\path\to\agent-relay-plugins
