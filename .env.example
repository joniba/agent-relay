# agent-relay — cross-machine configuration template.
#
# Copy this to `.env` (gitignored) and fill in your values:
#     cp .env.example extension/.env      # next to extension.mjs (recommended)
#   or place it at the repo root, or point $AGENT_RELAY_ENV_FILE at it.
#
# The extension auto-loads it at startup. Values already exported in your shell
# take precedence (the file only fills gaps), so you can still override ad-hoc.
#
# GOTCHA: quote any value containing '#' (e.g. an Entra guest UPN) — otherwise the
# parser treats '#' as the start of a comment and truncates the value.

AGENT_RELAY_TRANSPORT=postgres
AGENT_RELAY_PG_HOST=pg-agent-relay-<unique>.postgres.database.azure.com
AGENT_RELAY_PG_USER="<your-entra-admin-upn>"
AGENT_RELAY_PG_DB=agentrelay

# Mint the Entra token as the DB admin via an isolated `az` profile. Omit if your
# default `az login` is already that identity.
# AZURE_CONFIG_DIR=C:\path\to\.azure-relay

# Optional display label shown beside this session in the roster (defaults to the
# machine hostname).
# AGENT_RELAY_HOST=laptop
